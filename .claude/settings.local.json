{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "5000000"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:ai.pydantic.dev)",
      "WebFetch(domain:pytest-qt.readthedocs.io)",
      "WebFetch(domain:ilmanzo.github.io)",
      "Read(//workspaces/**)",
      "Read(//home/vscode/**)",
      "Bash(git *)",
      "Bash(uv:*)",
      "Bash(timeout:*)",
      "Bash(QT_QPA_PLATFORM=offscreen uv run pytest:*)",
      "Bash(make:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh label list:*)",
      "Bash(docker build:*)",
      "Bash(docker volume:*)",
      "Bash(sqlite3:*)",
      "Bash(python3:*)",
      "Bash(code --list-extensions)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(pkill:*)",
      "Bash(mount:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(ln:*)",
      "Bash(ln -s:*)",
      "Bash(git commit:*)",
      "Bash(PYTHONPATH=\"\" VIRTUAL_ENV=\"\" .venv/bin/python:*)",
      "Bash(# Merge:*)",
      "Bash(done)",
      "Bash(.venv/bin/mypy src/lorairo/database/db_repository.py src/lorairo/database/db_manager.py src/lorairo/gui/services/search_filter_service.py src/lorairo/gui/widgets/filter_search_panel.py --ignore-missing-imports 2>&1 | tail -20)",
      "Skill(save-session)",
      "Skill(planning)",
      "Skill(implement)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_session_start.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_session_end.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_assistant_response_checker.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_git_grep_enforcement.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_pre_commands.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_plan_read_redirect.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_stop_words.py"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_post_plan_mode.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/LoRAIro/.claude/hooks/hook_response_monitor.py"
          }
        ]
      }
    ]
  },
  "language": "japanese"
}
