{
  "description": "LoRAIro 固有の response_monitor override (旧 hook_stop_words_rules.json から機械変換)",
  "ng_words": [
    {
      "keywords": [
        "だろう",
        "かもしれ",
        "おそらく",
        "推測",
        "I guess",
        "seems like"
      ],
      "message": "[推測ルール] 推測は禁止。確認した？テストした？",
      "exclude_patterns": [
        "推測ルール",
        "推測表現",
        "推測禁止",
        "推測は禁止",
        "推測を使",
        "推測を避",
        "推測が検出",
        "推測.*キーワード",
        "キーワード.*推測",
        "かもしれない(が|けど|と|という|として)",
        "かもしれません(が|けど|。)",
        "かもしれ(ない|ませ).*（"
      ]
    },
    {
      "keywords": [
        "ついでに",
        "せっかくなので",
        "念のため"
      ],
      "message": "[追加作業ルール] 指示外の追加作業は禁止",
      "exclude_patterns": [
        "ついでに確認",
        "ついでに言",
        "ついでに述べ"
      ]
    },
    {
      "keywords": [
        "ドキュメントを読まずに",
        "コードを読まずに"
      ],
      "message": "[ドキュメント参照ルール] ドキュメント優先ルールを無視してない？"
    },
    {
      "keywords": [
        "重要なのは",
        "本章では",
        "ここでは",
        "まとめると",
        "要するに",
        "に他ならない",
        "にほかならない"
      ],
      "message": "[予告と総括ルール] 予告・総括の定型。中身を直接書け"
    },
    {
      "keywords": [
        "正面から"
      ],
      "message": "[正面からルール] 「正面から」は姿勢の宣言だけ。中身を書け"
    },
    {
      "keywords": [
        "不可欠",
        "核心的",
        "鍵となる",
        "根本的",
        "多角的",
        "包括的",
        "総合的"
      ],
      "message": "[空虚な形容ルール] 空虚な形容。強調ではなく主張の中身を説明しろ"
    },
    {
      "keywords": [
        "掘り下げ",
        "深掘り",
        "言語化",
        "触れる",
        "言及"
      ],
      "message": "[空虚な動詞ルール] 空虚な動詞。何をどう書いたかを示せ"
    },
    {
      "keywords": [
        "非常に",
        "極めて",
        "大いに"
      ],
      "message": "[空虚な強調ルール] 中身のない強調。具体を書け"
    },
    {
      "keywords": [
        "において",
        "という側面",
        "の観点から"
      ],
      "message": "[接続の型ルール] 新情報のない接続の型。具体的に書け"
    },
    {
      "keywords": [
        "さらに",
        "また",
        "加えて"
      ],
      "message": "[接続連打ルール] 接続詞の連打。情報を足さずに繋ぐな",
      "threshold": 3
    }
  ]
}
