{
  "推測ルール": {
    "keywords": ["だろう", "かもしれ", "おそらく", "推測", "I guess", "seems like"],
    "message": "推測は禁止。確認した？テストした？",
    "exclude_patterns": [
      "推測ルール",
      "推測表現",
      "推測禁止",
      "推測は禁止",
      "推測を使",
      "推測を避",
      "推測が検出",
      "推測.*キーワード",
      "キーワード.*推測",
      "かもしれない(が|けど|と|という|として)",
      "かもしれません(が|けど|。)",
      "かもしれ(ない|ませ).*（"
    ]
  },
  "追加作業ルール": {
    "keywords": ["ついでに", "せっかくなので", "念のため"],
    "message": "指示外の追加作業は禁止",
    "exclude_patterns": [
      "ついでに確認",
      "ついでに言",
      "ついでに述べ"
    ]
  },
  "ドキュメント参照ルール": {
    "keywords": ["ドキュメントを読まずに", "コードを読まずに"],
    "message": "ドキュメント優先ルールを無視してない？",
    "exclude_patterns": []
  },
  "予告と総括ルール": {
    "keywords": ["重要なのは", "本章では", "ここでは", "まとめると", "要するに", "に他ならない", "にほかならない"],
    "message": "予告・総括の定型。中身を直接書け",
    "exclude_patterns": []
  },
  "正面からルール": {
    "keywords": ["正面から"],
    "message": "「正面から」は姿勢の宣言だけ。中身を書け",
    "exclude_patterns": []
  },
  "空虚な形容ルール": {
    "keywords": ["不可欠", "核心的", "鍵となる", "根本的", "多角的", "包括的", "総合的"],
    "message": "空虚な形容。強調ではなく主張の中身を説明しろ",
    "exclude_patterns": []
  },
  "空虚な動詞ルール": {
    "keywords": ["掘り下げ", "深掘り", "言語化", "触れる", "言及"],
    "message": "空虚な動詞。何をどう書いたかを示せ",
    "exclude_patterns": []
  },
  "空虚な強調ルール": {
    "keywords": ["非常に", "極めて", "大いに"],
    "message": "中身のない強調。具体を書け",
    "exclude_patterns": []
  },
  "接続の型ルール": {
    "keywords": ["において", "という側面", "の観点から"],
    "message": "新情報のない接続の型。具体的に書け",
    "exclude_patterns": []
  },
  "接続連打ルール": {
    "keywords": ["さらに", "また", "加えて"],
    "threshold": 3,
    "message": "接続詞の連打。情報を足さずに繋ぐな",
    "exclude_patterns": []
  }
}
