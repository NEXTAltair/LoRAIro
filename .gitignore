# Agent worktree チェックアウト (.agents/worktree/<branch>。git worktree の実体、追跡しない)
.agents/worktree/

# 外部 skill の導入状態・退避先 (scripts/install_agent_skills.py が管理)
.agents/skills/.installed-lock-hashes.json
.agents/skills/.pending-replace/

# 外部ソース由来の skills は追跡しない (導入元は skills-lock.json が SSoT、
# 復元は scripts/install_agent_skills.py / make setup が行う)。
# LoRAIro 固有 skill のみ whitelist で追跡する
.agents/skills/*
!.agents/skills/agent-pr-autoloop
!.agents/skills/agent-pr-maintainer
!.agents/skills/check-existing
!.agents/skills/context7-openclaw-research
